@model GLMS.Models.ServiceRequest

@{
    ViewData["Title"] = "Delete Service Request";
}

<h1>Delete Service Request</h1>

<h4>Are you sure you want to delete this service request?</h4>

<div class="mb-3">
    <strong>Contract:</strong> @Model.Contract?.Id
</div>

<div class="mb-3">
    <strong>Client:</strong> @Model.Contract?.Client?.Name
</div>

<div class="mb-3">
    <strong>Description:</strong> @Model.Description
</div>

<div class="mb-3">
    <strong>Cost USD:</strong> @Model.CostUSD
</div>

<div class="mb-3">
    <strong>Cost ZAR:</strong> @Model.CostZAR
</div>

<div class="mb-3">
    <strong>Status:</strong> @Model.Status
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>