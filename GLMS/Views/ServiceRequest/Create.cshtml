@model GLMS.Models.ServiceRequest

@{
    ViewData["Title"] = "Create Service Request";
}

<h1>Create Service Request</h1>

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="ContractId" class="form-label">Contract</label>
        <select asp-for="ContractId" asp-items="ViewBag.ContractId" class="form-control">
            <option value="">-- Select Contract --</option>
        </select>
        <span asp-validation-for="ContractId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <input asp-for="Description" class="form-control" />
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CostUSD" class="form-label">Cost in USD</label>
        <input asp-for="CostUSD" class="form-control" />
        <span asp-validation-for="CostUSD" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Status" class="form-label"></label>
        <input asp-for="Status" class="form-control" />
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Save Service Request</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}