@model IEnumerable<GLMS.Models.ServiceRequest>

@{
    ViewData["Title"] = "Service Requests";
}

<h1>Service Requests</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Service Request</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Contract</th>
            <th>Client</th>
            <th>Description</th>
            <th>Cost</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var request in Model)
        {
            <tr>
                <td>@request.Contract?.Id</td>
                <td>@request.Contract?.Client?.Name</td>
                <td>@request.Description</td>
                <td>@request.Cost</td>
                <td>@request.Status</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@request.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@request.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>