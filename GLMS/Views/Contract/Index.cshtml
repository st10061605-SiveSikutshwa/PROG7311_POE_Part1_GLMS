@model IEnumerable<GLMS.Models.Contract>

@{
    ViewData["Title"] = "Contracts";
}

<h1>Contracts</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Contract</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Client</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Status</th>
            <th>Service Level</th>
            <th>Agreement</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var contract in Model)
        {
            <tr>
                <td>@contract.Client?.Name</td>
                <td>@contract.StartDate.ToShortDateString()</td>
                <td>@contract.EndDate.ToShortDateString()</td>
                <td>@contract.Status</td>
                <td>@contract.ServiceLevel</td>
                <td>
                    @if (!string.IsNullOrEmpty(contract.SignedAgreementPath))
                    {
                        <a asp-action="DownloadAgreement" asp-route-id="@contract.Id" class="btn btn-info btn-sm">Download PDF</a>
                    }
                    else
                    {
                        <span>No File</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@contract.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@contract.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>

            </tr>
        }
    </tbody>
</table>