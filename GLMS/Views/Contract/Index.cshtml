@model GLMS.ViewModels.ContractFilterViewModel

@{
    ViewData["Title"] = "Contracts";
}

<h1>Contracts</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Contract</a>
</p>

<!-- This form allows the user to filter contracts by status and date range -->
<form asp-action="Index" method="get" class="row g-3 mb-4">
    <div class="col-md-3">
        <label class="form-label">Status</label>
        <select name="status" class="form-control">
            <option value="">-- All Statuses --</option>
            <option value="Draft" selected="@(Model.Status == "Draft")">Draft</option>
            <option value="Active" selected="@(Model.Status == "Active")">Active</option>
            <option value="Expired" selected="@(Model.Status == "Expired")">Expired</option>
            <option value="On Hold" selected="@(Model.Status == "On Hold")">On Hold</option>
        </select>
    </div>

    <div class="col-md-3">
        <label class="form-label">Start Date From</label>
        <input type="date" name="startDateFrom" value="@(Model.StartDateFrom?.ToString("yyyy-MM-dd"))" class="form-control" />
    </div>

    <div class="col-md-3">
        <label class="form-label">End Date To</label>
        <input type="date" name="endDateTo" value="@(Model.EndDateTo?.ToString("yyyy-MM-dd"))" class="form-control" />
    </div>

    <div class="col-md-3 d-flex align-items-end">
        <button type="submit" class="btn btn-success me-2">Filter</button>
        <a asp-action="Index" class="btn btn-secondary">Clear</a>
    </div>
</form>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Client</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Status</th>
            <th>Service Level</th>
            <th>Agreement</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Contracts != null && Model.Contracts.Any())
        {
            foreach (var contract in Model.Contracts)
            {
                <tr>
                    <td>@contract.Client?.Name</td>
                    <td>@contract.StartDate.ToShortDateString()</td>
                    <td>@contract.EndDate.ToShortDateString()</td>
                    <td>@contract.Status</td>
                    <td>@contract.ServiceLevel</td>
                    <td>
                        @if (!string.IsNullOrEmpty(contract.SignedAgreementPath))
                        {
                            <a asp-action="DownloadAgreement" asp-route-id="@contract.Id" class="btn btn-info btn-sm">Download PDF</a>
                        }
                        else
                        {
                            <span>No File</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@contract.Id" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@contract.Id" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center">No contracts found.</td>
            </tr>
        }
    </tbody>
</table>